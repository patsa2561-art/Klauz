# meaningdiff — Caddy reverse proxy. Replace YOUR_DOMAIN with your real host.
# Caddy will auto-fetch a real Let's Encrypt cert, so Cloudflare can be set to
# SSL/TLS mode "Full (strict)".

YOUR_DOMAIN {
    encode gzip zstd
    reverse_proxy 127.0.0.1:7700 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
    }
    # Block large uploads — meaningdiff handles docs, not unbounded files.
    request_body {
        max_size 20MB
    }
    log {
        output file /var/log/caddy/meaningdiff.log
        format console
    }
}

# (Optional) Restrict to Cloudflare proxy IPs only — uncomment after testing.
# Cloudflare publishes the list at https://www.cloudflare.com/ips/
